# Harpyx Docker/default environment variables (.env)
#
# Purpose: provide the default developer stack configuration used by
# docker-compose.yml and by the applications before optional local overrides.
#
# Convention:
#   App configuration variables mirror appsettings keys, using `__` (double
#   underscore) as the hierarchical separator.
#   Example: appsettings key `Database:Host` -> env var `Database__Host`.
#
# Override chain for dotnet run / IDE:
#   appsettings.json -> .env -> .env.local -> process environment -> optional Key Vault
#
# Docker Compose reads this file automatically. Keep values here suitable for
# the Docker network. Put host-local overrides in .env.local.

COMPOSE_PROJECT_NAME=harpyx

# --- .NET / ASP.NET Core ---
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# --- Docker Compose published ports / container-only knobs ---
Docker__WebAppPort=8080
Docker__WebAppContainerPort=8080
Docker__SqlServerPublicPort=14330
Docker__SqlServerContainerPort=1433
Docker__MinioApiPort=9000
Docker__MinioApiContainerPort=9000
Docker__MinioConsolePort=9001
Docker__MinioConsoleContainerPort=9001
Docker__MinioDataPath=minio-data
Docker__RabbitMqAmqpPort=5672
Docker__RabbitMqAmqpContainerPort=5672
Docker__RabbitMqManagementPort=15672
Docker__RabbitMqManagementContainerPort=15672
Docker__OpenSearchHttpPort=9200
Docker__OpenSearchHttpContainerPort=9200
Docker__OpenSearchPerformancePort=9600
Docker__OpenSearchPerformanceContainerPort=9600
Docker__OpenSearchJavaOpts=-Xms512m -Xmx512m
Docker__RedisPort=6379
Docker__RedisContainerPort=6379
Docker__ClamAvPort=3310
Docker__ClamAvContainerPort=3310

# --- Database (SQL Server) ---
# Default local Docker setup:
#   Keep Database__Username=sa. The SQL Server container bootstraps the built-in
#   sa login automatically via MSSQL_SA_PASSWORD, which docker-compose.yml maps
#   from Database__Password.
# Shared or managed SQL Server setup:
#   Create your application login/user manually on that instance, then replace
#   Database__Username and Database__Password with those dedicated credentials.
Database__Host=sqlserver
Database__Port=1433
Database__Name=Harpyx
Database__Username=sa
Database__Password=Your!Passw0rd
Database__Encrypt=true
Database__TrustServerCertificate=true

# --- MinIO (S3-compatible storage) ---
Minio__Endpoint=minio:9000
Minio__AccessKey=harpyx
Minio__SecretKey=harpyxsecret

# --- RabbitMQ ---
RabbitMQ__HostName=rabbitmq
RabbitMQ__UserName=harpyx
RabbitMQ__Password=harpyxsecret

# --- Redis ---
Redis__ConnectionString=redis:6379

# --- Microsoft Entra ID (Azure AD) ---
Authentication__EntraId__Instance=https://login.microsoftonline.com/
Authentication__EntraId__TenantId=your-tenant-id
Authentication__EntraId__ClientId=your-client-id
Authentication__EntraId__ClientSecret=your-client-secret

# --- Google OAuth ---
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# --- Optional: seed admin users on startup ---
SeedOptions__AdminUsers__0__Provider=EntraId
SeedOptions__AdminUsers__0__UniqueId=your-admin-entra-object-id
SeedOptions__AdminUsers__0__Email=admin@example.com

# --- LLM API key encryption (AES-256-GCM) ---
# Generate with: dotnet script -e "Console.WriteLine(Convert.ToBase64String(System.Security.Cryptography.RandomNumberGenerator.GetBytes(32)))"
Encryption__MasterKey=your-base64-encoded-32-byte-key

# --- SMTP (invitation emails) ---
Email__Host=
Email__Port=587
Email__Username=
Email__Password=
Email__From=no-reply@example.com

# --- Malware scanning (ClamAV) ---
MalwareScan__Enabled=true
MalwareScan__FailClosed=true
MalwareScan__Host=clamav
MalwareScan__Port=3310
MalwareScan__TimeoutSeconds=15
MalwareScan__ChunkSizeBytes=65536

# --- OpenTelemetry (optional OTLP exporter, e.g. http://otel-collector:4317) ---
OpenTelemetry__Otlp__Endpoint=

# --- OpenSearch (security plugin enabled; use a strong password) ---
OpenSearch__Enabled=true
OpenSearch__Endpoint=https://opensearch:9200
OpenSearch__Username=admin
OpenSearch__Password=your-strong-opensearch-admin-password
OpenSearch__AllowInsecureTls=true
OpenSearch__IndexName=harpyx_chunks_v1
OpenSearch__IndexAlias=harpyx_chunks_current
OpenSearch__EmbeddingDimensions=1536
OpenSearch__RequestTimeoutSeconds=30

# --- Container-image bootstrap variables (read ONLY by docker-compose.yml) ---
# These names are imposed by upstream images and cannot be renamed.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=your-strong-opensearch-admin-password
