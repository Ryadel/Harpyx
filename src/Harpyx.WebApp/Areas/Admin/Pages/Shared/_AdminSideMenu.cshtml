<div class="card bg-base-100 shadow">
    <div class="card-body p-4 space-y-4">
        <h2 class="text-lg font-semibold">@SharedLocalizer["AdminMenuTitle"]</h2>

        <a asp-area="Admin" asp-page="/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:view-dashboard-outline"></iconify-icon>
                @SharedLocalizer["AdminOverviewTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminOverviewDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/Settings/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:tune"></iconify-icon>
                @SharedLocalizer["AdminGeneralSettingsTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminGeneralSettingsDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/Health/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:heart-pulse"></iconify-icon>
                @SharedLocalizer["AdminSystemHealthTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminSystemHealthDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/UsageLimits/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:gauge"></iconify-icon>
                @SharedLocalizer["AdminUsageLimitsTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminUsageLimitsDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/HostedModels/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:server-network"></iconify-icon>
                @SharedLocalizer["AdminHostedModelsTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminHostedModelsDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/Users/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:account-group-outline"></iconify-icon>
                @SharedLocalizer["AdminUsersTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminUsersDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/Tenants/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:office-building-outline"></iconify-icon>
                @SharedLocalizer["AdminTenantsTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminTenantsDescription"]
            </p>
        </a>

        <a asp-area="Admin" asp-page="/Invitations/Index" class="block rounded-lg border border-base-300 p-3 hover:bg-base-200">
            <div class="flex items-center gap-2 font-medium">
                <iconify-icon icon="mdi:email-fast-outline"></iconify-icon>
                @SharedLocalizer["AdminUserInvitationsTitle"]
            </div>
            <p class="mt-1 text-xs text-base-content/70">
                @SharedLocalizer["AdminUserInvitationsDescription"]
            </p>
        </a>
    </div>
</div>
