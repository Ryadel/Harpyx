@page
@model Harpyx.WebApp.Areas.Admin.Pages.Invitations.IndexModel
@{
    ViewData["Title"] = "Admin - Invitations";
}
@section SidePanel {
    <partial name="/Areas/Admin/Pages/Shared/_AdminSideMenu.cshtml" />
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <partial name="/Pages/Shared/_PageHeader.cshtml" model="@(new PageHeaderViewModel(
        Title: "User Invitations",
        Intro: "Send invitation emails for users who need access when self-registration is disabled."))" />

    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-5">
            <form method="post" asp-page-handler="Invite" class="grid gap-4 md:grid-cols-2">
                @Html.AntiForgeryToken()
                <div class="form-control md:col-span-2">
                    <label class="label">
                        <span class="label-text">Email</span>
                    </label>
                    <input asp-for="Email" type="email" class="input input-bordered w-full" />
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Invitation scope</span>
                    </label>
                    <select asp-for="Scope" asp-items="Model.ScopeOptions" class="select select-bordered w-full" id="Scope"></select>
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Expiration (days)</span>
                    </label>
                    <input asp-for="ExpiresInDays" type="number" min="1" max="30" class="input input-bordered w-full" />
                </div>

                <div class="form-control md:col-span-2" id="TenantField">
                    <label class="label">
                        <span class="label-text">Tenant (required for TenantMembership)</span>
                    </label>
                    <select asp-for="TenantId" asp-items="Model.TenantOptions" class="select select-bordered w-full">
                        <option value="">No tenant</option>
                    </select>
                </div>

                <div class="md:col-span-2 flex items-center gap-2">
                    <button type="submit" class="btn btn-primary mw-120">
                        <iconify-icon icon="mdi:email-send-outline"></iconify-icon>
                        Invite user
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h2 class="text-lg font-semibold">Invitation history</h2>
            @if (Model.Invitations.Count == 0)
            {
                <div class="mt-3">
                    <partial name="/Pages/Shared/_EmptyState.cshtml" model="@(new EmptyStateViewModel(
                        Message: "No invitations yet."))" />
                </div>
            }
            else
            {
                <div class="overflow-x-auto mt-3">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Scope</th>
                                <th>Tenant</th>
                                <th>Status</th>
                                <th>Expires</th>
                                <th>Invited By</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var invitation in Model.Invitations)
                        {
                            <tr>
                                <td class="font-medium">@invitation.Email</td>
                                <td>@invitation.Scope</td>
                                <td>@(string.IsNullOrWhiteSpace(invitation.TenantName) ? "-" : invitation.TenantName)</td>
                                <td>
                                    @{
                                        var badge = invitation.Status switch
                                        {
                                            Harpyx.Domain.Enums.UserInvitationStatus.Pending => "badge-info",
                                            Harpyx.Domain.Enums.UserInvitationStatus.Accepted => "badge-success",
                                            Harpyx.Domain.Enums.UserInvitationStatus.Revoked => "badge-ghost",
                                            Harpyx.Domain.Enums.UserInvitationStatus.Expired => "badge-warning",
                                            _ => "badge-ghost"
                                        };
                                    }
                                    <span class="badge @badge">@invitation.Status</span>
                                </td>
                                <td>@invitation.ExpiresAt.ToLocalTime().ToString("g")</td>
                                <td>@invitation.InvitedByEmail</td>
                                <td class="text-right">
                                    @if (invitation.Status == Harpyx.Domain.Enums.UserInvitationStatus.Pending)
                                    {
                                        <form method="post" asp-page-handler="Revoke" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="RevokeInvitationId" value="@invitation.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm text-error" title="Revoke" aria-label="Revoke">
                                                <iconify-icon icon="mdi:cancel"></iconify-icon>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        const scope = document.getElementById('Scope');
        const tenantField = document.getElementById('TenantField');
        if (!scope || !tenantField) {
            return;
        }

        function refresh() {
            const isTenantMembership = scope.value === 'TenantMembership';
            tenantField.style.display = isTenantMembership ? 'block' : 'none';
        }

        scope.addEventListener('change', refresh);
        refresh();
    })();
</script>
