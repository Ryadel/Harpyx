@page
@model Harpyx.WebApp.Areas.Admin.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Admin - Tenants";
}
@section SidePanel {
    <partial name="/Areas/Admin/Pages/Shared/_AdminSideMenu.cshtml" />
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <partial name="/Pages/Shared/_PageHeader.cshtml" model="@(new PageHeaderViewModel(
        Title: "Tenants",
        Intro: "Browse and manage all tenants in the platform lifecycle.",
        Actions: new[]
        {
            new PageActionViewModel(
                Label: "Add Tenant",
                Page: "/Tenants/Edit",
                Icon: "mdi:plus",
                RouteValues: new Dictionary<string, string> { ["area"] = "Admin" })
        }))" />

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            @if (Model.Tenants.Count == 0)
            {
                <partial name="/Pages/Shared/_EmptyState.cshtml" model="@(new EmptyStateViewModel(
                    Message: "No tenants yet.",
                    Action: new PageActionViewModel(
                        Label: "Add Tenant",
                        Page: "/Tenants/Edit",
                        Icon: "mdi:plus",
                        RouteValues: new Dictionary<string, string> { ["area"] = "Admin" })))" />
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Owner</th>
                                <th>Status</th>
                                <th>Public</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var tenant in Model.Tenants)
                        {
                            <tr>
                                <td class="font-medium">
                                    <span class="inline-flex items-center gap-2">
                                        <span>@tenant.Name</span>
                                        @if (tenant.IsPersonal)
                                        {
                                            <span class="badge badge-secondary badge-sm">Personal</span>
                                        }
                                    </span>
                                </td>
                                <td>@Model.OwnerEmailByTenantId[tenant.Id]</td>
                                <td>
                                    <span class="badge @(tenant.IsActive ? "badge-success" : "badge-ghost")">
                                        @(tenant.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(tenant.IsVisibleToAllUsers ? "badge-info" : "badge-ghost")">
                                        @(tenant.IsVisibleToAllUsers ? "Yes" : "No")
                                    </span>
                                </td>
                                <td class="text-right">
                                    <div class="inline-flex items-center gap-1">
                                        @if (Model.IsAllTenants || Model.CurrentTenantId != tenant.Id)
                                        {
                                            <form method="post" asp-page-handler="SetCurrent" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@tenant.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm" title="Set Current" aria-label="Set Current">
                                                    <iconify-icon icon="mdi:target-account"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        <a asp-area="Admin" asp-page="/Tenants/Edit" asp-route-id="@tenant.Id" class="btn btn-ghost btn-sm" title="Edit" aria-label="Edit">
                                            <iconify-icon icon="mdi:pencil"></iconify-icon>
                                        </a>
                                        @if (!tenant.IsPersonal)
                                        {
                                            <form method="post" asp-page-handler="Delete" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@tenant.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm text-error" title="Delete" aria-label="Delete">
                                                    <iconify-icon icon="mdi:delete"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
