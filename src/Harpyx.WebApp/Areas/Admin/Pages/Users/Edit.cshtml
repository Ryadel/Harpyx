@page "{id?}"
@model Harpyx.WebApp.Areas.Admin.Pages.Users.EditModel
@{
    ViewData["Title"] = Model.Id is null
        ? "Admin - Add User"
        : $"Admin - {Model.Email} - Edit";
}
@section SidePanel {
    <partial name="/Areas/Admin/Pages/Shared/_AdminSideMenu.cshtml" />
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h1 class="text-2xl font-semibold">@Model.Title</h1>
            <hr />
            <p class="text-sm text-base-content/70">
                Create or edit users, define their role, and set tenant memberships.
            </p>
        </div>
    </div>

    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-4">
            <form method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Email</span>
                    </label>
                    <input asp-for="Email" class="input input-bordered w-full" />
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Object Id</span>
                    </label>
                    <input asp-for="ObjectId" class="input input-bordered w-full" />
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Subject Id (sub)</span>
                    </label>
                    <input asp-for="SubjectId" class="input input-bordered w-full" />
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Role</span>
                    </label>
                    <select asp-for="Role" asp-items="Model.RoleOptions" class="select select-bordered w-full"></select>
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Tenants</span>
                    </label>
                    <select asp-for="SelectedTenantIds" asp-items="Model.TenantOptions" class="select select-bordered w-full" multiple size="8"></select>
                </div>

                <div class="form-control">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="IsActive" type="checkbox" class="checkbox" />
                        <span class="label-text">Active</span>
                    </label>
                </div>

                <div class="flex items-center gap-2">
                    <button type="submit" class="btn btn-primary mw-120">
                        <iconify-icon icon="mdi:content-save"></iconify-icon>
                        Save
                    </button>
                    <a asp-area="Admin" asp-page="/Users/Index" class="btn btn-ghost mw-120">
                        <iconify-icon icon="mdi:arrow-left"></iconify-icon>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
