@page
@model Harpyx.WebApp.Areas.Admin.Pages.Users.IndexModel
@section SidePanel {
    <partial name="/Areas/Admin/Pages/Shared/_AdminSideMenu.cshtml" />
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <partial name="/Pages/Shared/_PageHeader.cshtml" model="@(new PageHeaderViewModel(
        Title: "Users",
        Intro: "Browse and manage every application user, including roles and activation status.",
        Actions: new[]
        {
            new PageActionViewModel(
                Label: "Add User",
                Page: "/Users/Edit",
                Icon: "mdi:account-plus",
                RouteValues: new Dictionary<string, string> { ["area"] = "Admin" })
        }))" />

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            @if (Model.Users.Count == 0)
            {
                <partial name="/Pages/Shared/_EmptyState.cshtml" model="@(new EmptyStateViewModel(
                    Message: "No users yet.",
                    Action: new PageActionViewModel(
                        Label: "Add User",
                        Page: "/Users/Edit",
                        Icon: "mdi:account-plus",
                        RouteValues: new Dictionary<string, string> { ["area"] = "Admin" })))" />
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Last Login</th>
                                <th>Last Provider</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="font-medium">@user.Email</td>
                                <td>@user.Role</td>
                                <td>
                                    <span class="badge @(user.IsActive ? "badge-success" : "badge-ghost")">
                                        @(user.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@(user.LastLoginAt?.ToString("g") ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(user.LastLoginProvider) ? "-" : user.LastLoginProvider)</td>
                                <td class="text-right">
                                    <div class="inline-flex items-center gap-1">
                                        <a asp-area="Admin" asp-page="/Users/Edit" asp-route-id="@user.Id" class="btn btn-ghost btn-sm" title="Edit" aria-label="Edit">
                                            <iconify-icon icon="mdi:pencil"></iconify-icon>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm text-error"
                                                    onclick="return confirmDelete('@user.Email')"
                                                    title="Delete" aria-label="Delete">
                                                <iconify-icon icon="mdi:delete"></iconify-icon>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function confirmDelete(email) {
        return confirm(
            "Delete user '" + email + "'? If this user has a Personal tenant, it will also be deleted with all projects and documents.");
    }
</script>
