@page
@model Harpyx.WebApp.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="space-y-6">
    <partial name="_PageHeader" model="@(new PageHeaderViewModel(
        Title: Localizer["PageHeading"].Value,
        Intro: Localizer["Intro"].Value,
        Actions: new[]
        {
            new PageActionViewModel(
                Label: Localizer["AddTenantButton"].Value,
                Page: "/Tenants/Edit",
                Icon: "mdi:plus")
        }))" />

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            @if (Model.Tenants.Count == 0)
            {
                <partial name="_EmptyState" model="@(new EmptyStateViewModel(
                    Message: Localizer["NoTenants"].Value,
                    Action: new PageActionViewModel(
                        Label: Localizer["AddTenantButton"].Value,
                        Page: "/Tenants/Edit",
                        Icon: "mdi:plus")))" />
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>@Localizer["NameHeader"]</th>
                                <th>@Localizer["OwnerHeader"]</th>
                                <th>@Localizer["StatusHeader"]</th>
                                <th>@Localizer["PublicHeader"]</th>
                                <th class="text-right">@Localizer["ActionsHeader"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var tenant in Model.Tenants)
                        {
                            <tr>
                                <td class="font-medium">
                                    <span class="inline-flex items-center gap-2">
                                        <span>@tenant.Name</span>
                                        @if (tenant.IsPersonal)
                                        {
                                            <span class="badge badge-secondary badge-sm">@Localizer["PersonalBadge"]</span>
                                        }
                                    </span>
                                </td>
                                <td>@Model.OwnerEmailByTenantId[tenant.Id]</td>
                                <td>
                                    <span class="badge @(tenant.IsActive ? "badge-success" : "badge-ghost")">
                                        @(tenant.IsActive ? Localizer["ActiveStatus"] : Localizer["InactiveStatus"])
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(tenant.IsVisibleToAllUsers ? "badge-info" : "badge-ghost")">
                                        @(tenant.IsVisibleToAllUsers ? Localizer["Yes"] : Localizer["No"])
                                    </span>
                                </td>
                                <td class="text-right">
                                    <div class="inline-flex items-center gap-1">
                                        @if (Model.IsAllTenants || Model.CurrentTenantId != tenant.Id)
                                        {
                                            <form method="post" asp-page-handler="SetCurrent" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@tenant.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm" title="@Localizer["SetCurrentButton"]" aria-label="@Localizer["SetCurrentButton"]">
                                                    <iconify-icon icon="mdi:target-account"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        <a class="btn btn-ghost btn-sm" asp-page="/Tenants/Edit" asp-route-id="@tenant.Id" title="@Localizer["EditButton"]" aria-label="@Localizer["EditButton"]">
                                            <iconify-icon icon="mdi:pencil"></iconify-icon>
                                        </a>
                                        @if (!tenant.IsPersonal)
                                        {
                                            <form method="post" asp-page-handler="Delete" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@tenant.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm text-error" title="@Localizer["DeleteButton"]" aria-label="@Localizer["DeleteButton"]">
                                                    <iconify-icon icon="mdi:delete"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
