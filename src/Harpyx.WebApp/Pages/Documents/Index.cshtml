@page
@model Harpyx.WebApp.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-4">
            <h1 class="text-2xl font-semibold">Documents</h1>
            <p class="text-sm text-base-content/70">
                In this section you are redirected to project dashboards, where documents are uploaded, selected, and used as context for project chat and RAG retrieval.
            </p>
            <a class="btn btn-primary btn-sm" asp-page="/Projects/Index">
                Go to Projects
            </a>
        </div>
    </div>
</div>
