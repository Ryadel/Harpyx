@page
@model Harpyx.WebApp.Pages.Documents.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-4">
            <h1 class="text-2xl font-semibold">@Localizer["PageHeading"]</h1>
            <p class="text-sm text-base-content/70">
                @Localizer["Intro"]
            </p>
            <a class="btn btn-primary btn-sm" asp-page="/Projects/Index">
                @Localizer["GoToProjects"]
            </a>
        </div>
    </div>
</div>
