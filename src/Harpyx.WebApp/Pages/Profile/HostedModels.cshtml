@page
@model Harpyx.WebApp.Pages.Profile.HostedModelsModel
@{
    ViewData["Title"] = "Hosted Models";
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-3">
            <div class="flex flex-wrap items-center gap-3">
                <h1 class="text-2xl font-semibold">Hosted Models</h1>
                <div class="ml-auto">
                    <a class="btn btn-ghost btn-sm" asp-page="/Profile/Index">
                        <iconify-icon icon="mdi:arrow-left"></iconify-icon>
                        Back to Profile
                    </a>
                </div>
            </div>
            <p class="text-sm text-base-content/70">
                Choose models already configured by this Harpyx instance. No API key or internal URL is required here.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    @if (!Model.HasAnyModels)
    {
        <div class="card bg-base-100 shadow">
            <div class="card-body space-y-3">
                <h2 class="text-lg font-semibold">No hosted models available</h2>
                <p class="text-sm text-base-content/70">
                    The platform has not published hosted models yet. You can keep using your personal API providers.
                </p>
                <a class="btn btn-primary btn-sm w-fit" asp-page="/Profile/Edit">
                    <iconify-icon icon="mdi:plus"></iconify-icon>
                    Add Provider
                </a>
            </div>
        </div>
    }
    else
    {
        <form method="post" class="card bg-base-100 shadow">
            @Html.AntiForgeryToken()
            <div class="card-body space-y-4">
                <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
                    <div class="rounded-box border border-base-300 bg-base-200 p-4">
                        <h2 class="text-lg font-semibold">Chat</h2>
                        <p class="text-sm text-base-content/70">Answers and conversations.</p>
                        <select asp-for="ChatModelId" asp-items="Model.ChatOptions" class="select select-bordered mt-3 w-full">
                            <option value="">Keep current default</option>
                        </select>
                    </div>

                    <div class="rounded-box border border-base-300 bg-base-200 p-4">
                        <h2 class="text-lg font-semibold">RAG Embedding</h2>
                        <p class="text-sm text-base-content/70">Document indexing and retrieval.</p>
                        <select asp-for="RagEmbeddingModelId" asp-items="Model.RagOptions" class="select select-bordered mt-3 w-full">
                            <option value="">Keep current default</option>
                        </select>
                    </div>

                    <div class="rounded-box border border-base-300 bg-base-200 p-4">
                        <h2 class="text-lg font-semibold">OCR</h2>
                        <p class="text-sm text-base-content/70">Text extraction from visual documents.</p>
                        <select asp-for="OcrModelId" asp-items="Model.OcrOptions" class="select select-bordered mt-3 w-full">
                            <option value="">Keep current default</option>
                        </select>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <button type="submit" class="btn btn-primary mw-120">
                        <iconify-icon icon="mdi:content-save"></iconify-icon>
                        Save
                    </button>
                    <a asp-page="/Profile/Index" class="btn btn-ghost mw-120">
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    }
</div>
