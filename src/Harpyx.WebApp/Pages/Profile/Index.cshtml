@page
@model Harpyx.WebApp.Pages.Profile.IndexModel
@using Harpyx.Domain.Enums
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body space-y-3">
            <div class="flex items-center gap-4">
                <h1 class="text-2xl font-semibold">@Localizer["PageHeading"]</h1>
                <div class="ml-auto">
                    <div class="flex flex-wrap gap-2">
                        <a class="btn btn-outline btn-sm" asp-page="/Profile/HostedModels">
                            <iconify-icon icon="mdi:server-network"></iconify-icon>
                            @Localizer["HostedModelsButton"]
                        </a>
                        <a class="btn btn-primary btn-sm" asp-page="/Profile/Edit">
                            <iconify-icon icon="mdi:plus"></iconify-icon>
                            @Localizer["AddProviderButton"]
                        </a>
                    </div>
                </div>
            </div>
            <hr />
            <p class="text-sm text-base-content/70">
                @Localizer["IntroBeforeCount"] <strong>@Localizer["ThreeCount"]</strong> @Localizer["IntroAfterCount"]
            </p>
            <div class="rounded-box border border-base-300 bg-base-200 p-3 text-sm text-base-content/80">
                <ul class="list-disc pl-5 space-y-1">
                    <li>
                        <strong>@Localizer["ChatProviderTitle"]</strong> (<i>@Localizer["RequiredLabel"]</i>):
                        @Localizer["ChatProviderDescription"]
                        @Localizer["ChatProviderWarning"]
                    </li>
                    <li>
                        <strong>@Localizer["RagProviderTitle"]</strong> (<i>@Localizer["OptionalRecommendedLabel"]</i>):
                        @Localizer["RagProviderDescription"]
                        @Localizer["RagProviderWarning"]
                    </li>
                    <li>
                        <strong>@Localizer["OcrProviderTitle"]</strong> (<i>@Localizer["OptionalLabel"]</i>):
                        @Localizer["OcrProviderDescription"]
                        @Localizer["OcrProviderWarning"]
                    </li>
                </ul>
            </div>
            <p class="text-sm text-base-content/70">
                @Localizer["BestExperiencePrefix"] <span class="font-semibold">@Localizer["ChatLabel"]</span> @Localizer["BestExperienceMiddle"] <span class="font-semibold">@Localizer["RagLabel"]</span> @Localizer["BestExperienceSuffix"]
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    @if (!Model.HasChatModelConfigured)
    {
        <div class="alert alert-warning">
            <span>@Localizer["NoChatProviderPrefix"] <strong>@Localizer["ChatLabel"]</strong> @Localizer["NoChatProviderSuffix"]</span>
        </div>
    }
    @if (!Model.HasRagProviderConfigured)
    {
        <div class="alert alert-warning">
            <span>@Localizer["NoRagProviderPrefix"] <strong>@Localizer["RagLabel"]</strong> @Localizer["NoRagProviderSuffix"]</span>
        </div>
    }
    @if (!Model.HasOcrModelConfigured)
    {
        <div class="alert alert-warning">
            <span>@Localizer["NoOcrProviderPrefix"] <strong>@Localizer["OcrLabel"]</strong> @Localizer["NoOcrProviderSuffix"]</span>
        </div>
    }

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            @if (Model.Providers.Count == 0)
            {
                <div class="rounded-lg border border-base-200 bg-base-100 p-4 text-sm text-base-content/70">
                    <div class="flex flex-wrap items-center gap-3">
                        <span>@Localizer["NoProviders"]</span>
                        <a class="btn btn-primary btn-sm" asp-page="/Profile/Edit">
                            <iconify-icon icon="mdi:plus"></iconify-icon>
                            @Localizer["AddProviderButton"]
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>@Localizer["NameHeader"]</th>
                                <th>@Localizer["ProviderHeader"]</th>
                                <th>@Localizer["EndpointHeader"]</th>
                                <th>@Localizer["TypeHeader"]</th>
                                <th>@Localizer["ApiKeyHeader"]</th>
                                <th>@Localizer["ChatModelHeader"]</th>
                                <th>@Localizer["RagModelHeader"]</th>
                                <th>@Localizer["OcrModelHeader"]</th>
                                <th>@Localizer["DefaultChatHeader"]</th>
                                <th>@Localizer["DefaultRagHeader"]</th>
                                <th>@Localizer["DefaultOcrHeader"]</th>
                                <th>@Localizer["UsedByProjectsHeader"]</th>
                                <th class="text-right">@Localizer["ActionsHeader"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var provider in Model.Providers)
                        {
                            <tr>
                                <td class="font-medium">@(string.IsNullOrWhiteSpace(provider.Name) ? "-" : provider.Name)</td>
                                <td class="font-medium">@provider.GetName()</td>
                                <td class="font-mono text-xs">@(string.IsNullOrWhiteSpace(provider.BaseUrl) ? "-" : provider.BaseUrl)</td>
                                <td>
                                    @if (provider.SupportsChat)
                                    {
                                        <span class="badge badge-outline mr-1">Chat</span>
                                    }
                                    @if (provider.SupportsRagEmbedding)
                                    {
                                        <span class="badge badge-outline">RAG</span>
                                    }
                                    @if (provider.SupportsOcr)
                                    {
                                        <span class="badge badge-outline">OCR</span>
                                    }
                                </td>
                                <td><span class="font-mono text-sm">****@provider.ApiKeyLast4</span></td>
                                <td>@(string.IsNullOrWhiteSpace(provider.ChatModel) ? "-" : provider.ChatModel)</td>
                                <td>@(string.IsNullOrWhiteSpace(provider.RagEmbeddingModel) ? "-" : provider.RagEmbeddingModel)</td>
                                <td>@(string.IsNullOrWhiteSpace(provider.OcrModel) ? "-" : provider.OcrModel)</td>
                                <td>
                                    <span class="badge @(provider.IsDefaultChat ? "badge-primary" : "badge-ghost") badge-sm">
                                        @(provider.IsDefaultChat ? Localizer["Yes"] : Localizer["No"])
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(provider.IsDefaultRagEmbedding ? "badge-primary" : "badge-ghost") badge-sm">
                                        @(provider.IsDefaultRagEmbedding ? Localizer["Yes"] : Localizer["No"])
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(provider.IsDefaultOcr ? "badge-primary" : "badge-ghost") badge-sm">
                                        @(provider.IsDefaultOcr ? Localizer["Yes"] : Localizer["No"])
                                    </span>
                                </td>
                                <td>@provider.UsedByProjectCount</td>
                                <td class="text-right">
                                    <div class="inline-flex items-center gap-1">
                                        <a class="btn btn-ghost btn-sm"
                                           asp-page="/Profile/Edit"
                                           asp-route-provider="@provider.Provider"
                                           title="@Localizer["EditButton"]" aria-label="@Localizer["EditButton"]">
                                            <iconify-icon icon="mdi:pencil"></iconify-icon>
                                        </a>
                                        @if (provider.SupportsChat && !provider.IsDefaultChat)
                                        {
                                            <form method="post" asp-page-handler="SetDefault" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="SetDefaultUsage" value="@LlmProviderType.Chat" />
                                                <input type="hidden" name="SetDefaultModelId" value="@provider.ChatModelId" />
                                                <button type="submit" class="btn btn-ghost btn-sm" title="@Localizer["SetDefaultChatButton"]" aria-label="@Localizer["SetDefaultChatButton"]">
                                                    <iconify-icon icon="mdi:chat"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        @if (provider.SupportsRagEmbedding && !provider.IsDefaultRagEmbedding)
                                        {
                                            <form method="post" asp-page-handler="SetDefault" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="SetDefaultUsage" value="@LlmProviderType.RagEmbedding" />
                                                <input type="hidden" name="SetDefaultModelId" value="@provider.RagEmbeddingModelId" />
                                                <button type="submit" class="btn btn-ghost btn-sm" title="@Localizer["SetDefaultRagButton"]" aria-label="@Localizer["SetDefaultRagButton"]">
                                                    <iconify-icon icon="mdi:database-search"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        @if (provider.SupportsOcr && !provider.IsDefaultOcr)
                                        {
                                            <form method="post" asp-page-handler="SetDefault" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="SetDefaultUsage" value="@LlmProviderType.Ocr" />
                                                <input type="hidden" name="SetDefaultModelId" value="@provider.OcrModelId" />
                                                <button type="submit" class="btn btn-ghost btn-sm" title="@Localizer["SetDefaultOcrButton"]" aria-label="@Localizer["SetDefaultOcrButton"]">
                                                    <iconify-icon icon="mdi:ocr"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="Delete" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="DeleteProvider" value="@provider.Provider" />
                                            <button type="submit" class="btn btn-ghost btn-sm text-error"
                                                    data-provider-name="@provider.GetName()"
                                                    onclick="return confirmDelete(this.dataset.providerName, @provider.UsedByProjectCount)"
                                                    title="@Localizer["DeleteButton"]" aria-label="@Localizer["DeleteButton"]">
                                                <iconify-icon icon="mdi:delete"></iconify-icon>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function confirmDelete(provider, usedByProjects) {
        if (usedByProjects > 0) {
            return confirm(
                "@Localizer["DeleteUsedProviderPrefix"]" + usedByProjects + "@Localizer["DeleteUsedProviderSuffix"]");
        }

        return confirm("@Localizer["DeleteProviderPrefix"]" + provider + "@Localizer["DeleteProviderSuffix"]");
    }
</script>
