@page
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.OpenIdConnect
@model Harpyx.WebApp.Pages.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
    var brandHero = new BrandHeroViewModel(
        SharedLocalizer["BrandHeroTitle"].Value,
        SharedLocalizer["BrandHeroSubtitle"].Value);
}

<div class="grid gap-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <div class="flex flex-col gap-4">
                <partial name="_BrandHero" model="brandHero" />

                <div class="flex items-center gap-2 md:justify-center">
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <form asp-controller="Account" asp-action="LoginGoogle" method="post" class="m-0">
                            <button type="submit" class="btn btn-primary">
                                <iconify-icon icon="simple-icons:google"></iconify-icon>
                                @Localizer["LoginWithGoogle"]
                            </button>
                        </form>
                        <form asp-controller="Account" asp-action="LoginEntra" method="post" class="m-0">
                            <button type="submit" class="btn btn-primary">
                                <iconify-icon icon="simple-icons:microsoft"></iconify-icon>
                                @Localizer["LoginWithMicrosoft"]
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-page="/Workspaces/Index" class="btn btn-primary mw-120">
                            <iconify-icon icon="mdi:folder-open"></iconify-icon>
                            @Localizer["GoToProjects"]
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline mw-120">
                                <iconify-icon icon="mdi:logout"></iconify-icon>
                                @Localizer["Logout"]
                            </button>
                        </form>
                    }
                </div>
            </div>

            <partial name="_SignedInAs" />
        </div>
    </div>

