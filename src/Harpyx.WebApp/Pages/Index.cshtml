@page
@model Harpyx.WebApp.Pages.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="space-y-14 pb-10">
    <div class="fixed right-0 top-0 z-[60] hidden h-36 w-36 overflow-hidden md:block">
        <a class="absolute right-[-3.75rem] top-8 flex w-56 rotate-45 items-center justify-center gap-1.5 bg-zinc-950 px-3 py-1.5 text-xs font-semibold text-white shadow-lg transition hover:bg-base-content"
           href="https://github.com/Ryadel/Harpyx"
           target="_blank"
           rel="noopener noreferrer">
            <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            <span>@SharedLocalizer["GitHub"]</span>
        </a>
    </div>

    <section class="grid items-center gap-10 py-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="space-y-7">
            <div class="inline-flex items-center gap-2 rounded-full border border-base-content/15 bg-base-content px-4 py-2 text-sm font-semibold text-base-100 shadow">
                <iconify-icon icon="mdi:source-branch"></iconify-icon>
                @Localizer["HeroBadge"]
            </div>

            <div class="space-y-5">
                <h1 class="max-w-4xl text-4xl font-bold leading-tight md:text-6xl">
                    @Localizer["HeroTitle"]
                </h1>
                <p class="max-w-3xl text-lg leading-8 text-base-content/75">
                    @Localizer["HeroText"]
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                @if (isAuthenticated)
                {
                    <a asp-page="/Workspaces/Index" class="btn btn-primary">
                        <iconify-icon icon="mdi:folder-open-outline"></iconify-icon>
                        @Localizer["OpenWorkspaces"]
                    </a>
                    <a asp-page="/Projects/Index" class="btn btn-outline">
                        <iconify-icon icon="mdi:view-dashboard-outline"></iconify-icon>
                        @Localizer["OpenProjects"]
                    </a>
                }
                else
                {
                    <a asp-page="/Account/Login" asp-route-mode="signup" class="btn btn-primary mw-160">
                        <iconify-icon icon="mdi:account-plus-outline"></iconify-icon>
                        @SharedLocalizer["CreateAccount"]
                    </a>
                    <a asp-page="/Account/Login" class="btn btn-outline mw-160">
                        <iconify-icon icon="mdi:login"></iconify-icon>
                        @SharedLocalizer["Login"]
                    </a>
                }
                <a href="https://github.com/Ryadel/Harpyx" target="_blank" rel="noopener noreferrer" class="btn mw-160 border-zinc-950 bg-zinc-950 text-white hover:bg-base-content sm:ml-auto">
                    <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                    <span>@Localizer["ViewOnGitHub"]</span>
                </a>
            </div>

            <div class="flex flex-wrap gap-2 text-sm text-base-content/70">
                <span class="rounded-full bg-base-200 px-3 py-1">@Localizer["PillOpenSource"]</span>
                <span class="rounded-full bg-base-200 px-3 py-1">@Localizer["PillSelfHosted"]</span>
                <span class="rounded-full bg-base-200 px-3 py-1">@Localizer["PillDocuments"]</span>
                <span class="rounded-full bg-base-200 px-3 py-1">@Localizer["PillLocalModels"]</span>
            </div>
        </div>

        <div class="rounded-lg border border-base-300 bg-base-100 p-6 shadow-xl">
            <div class="flex items-center justify-between gap-4 border-b border-base-300 pb-4">
                <div class="flex items-center gap-3">
                    <span class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-base-200 text-base-content">
                        <partial name="_SVG.Logo.NavBar" />
                    </span>
                    <div>
                        <p class="font-semibold">Harpyx</p>
                        <p class="text-sm text-base-content/60">@Localizer["PreviewSubtitle"]</p>
                    </div>
                </div>
                <span class="badge badge-primary badge-outline">@Localizer["PreviewStatus"]</span>
            </div>

            <div class="mt-6 space-y-4">
                <div class="rounded-lg bg-base-200 p-4">
                    <div class="flex items-center justify-between gap-3">
                        <p class="font-semibold">@Localizer["PreviewProjectTitle"]</p>
                        <span class="text-xs text-base-content/60">@Localizer["PreviewProjectCount"]</span>
                    </div>
                    <div class="mt-3 grid gap-2 sm:grid-cols-3">
                        <span class="rounded-md bg-base-100 px-3 py-2 text-sm">@Localizer["PreviewDocPdf"]</span>
                        <span class="rounded-md bg-base-100 px-3 py-2 text-sm">@Localizer["PreviewDocWeb"]</span>
                        <span class="rounded-md bg-base-100 px-3 py-2 text-sm">@Localizer["PreviewDocOffice"]</span>
                    </div>
                </div>

                <div class="grid gap-3 sm:grid-cols-3">
                    <div class="rounded-lg border border-base-300 p-4">
                        <iconify-icon icon="mdi:cloud-upload-outline" class="text-2xl text-primary"></iconify-icon>
                        <p class="mt-2 text-sm font-semibold">@Localizer["WorkflowUpload"]</p>
                    </div>
                    <div class="rounded-lg border border-base-300 p-4">
                        <iconify-icon icon="mdi:database-search-outline" class="text-2xl text-primary"></iconify-icon>
                        <p class="mt-2 text-sm font-semibold">@Localizer["WorkflowIndex"]</p>
                    </div>
                    <div class="rounded-lg border border-base-300 p-4">
                        <iconify-icon icon="mdi:chat-question-outline" class="text-2xl text-primary"></iconify-icon>
                        <p class="mt-2 text-sm font-semibold">@Localizer["WorkflowAsk"]</p>
                    </div>
                </div>

                <div class="rounded-lg border border-base-300 p-4">
                    <p class="text-sm font-semibold text-base-content/70">@Localizer["PreviewQuestionLabel"]</p>
                    <p class="mt-2 text-lg font-semibold">@Localizer["PreviewQuestion"]</p>
                    <p class="mt-3 text-sm leading-6 text-base-content/70">@Localizer["PreviewAnswer"]</p>
                </div>
            </div>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
        <article class="rounded-lg border border-base-300 bg-base-100 p-6">
            <iconify-icon icon="mdi:file-tree-outline" class="text-3xl text-primary"></iconify-icon>
            <h2 class="mt-4 text-xl font-bold">@Localizer["FeatureDocumentsTitle"]</h2>
            <p class="mt-3 leading-7 text-base-content/70">@Localizer["FeatureDocumentsText"]</p>
        </article>
        <article class="rounded-lg border border-base-300 bg-base-100 p-6">
            <iconify-icon icon="mdi:account-lock-outline" class="text-3xl text-primary"></iconify-icon>
            <h2 class="mt-4 text-xl font-bold">@Localizer["FeatureAccessTitle"]</h2>
            <p class="mt-3 leading-7 text-base-content/70">@Localizer["FeatureAccessText"]</p>
        </article>
        <article class="rounded-lg border border-base-300 bg-base-100 p-6">
            <iconify-icon icon="mdi:robot-outline" class="text-3xl text-primary"></iconify-icon>
            <h2 class="mt-4 text-xl font-bold">@Localizer["FeatureModelsTitle"]</h2>
            <p class="mt-3 leading-7 text-base-content/70">@Localizer["FeatureModelsText"]</p>
        </article>
    </section>

    <section class="grid gap-8 rounded-lg border border-base-300 bg-base-100 p-7 lg:grid-cols-2">
        <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">@Localizer["NotebookEyebrow"]</p>
            <h2 class="mt-3 text-3xl font-bold">@Localizer["NotebookTitle"]</h2>
        </div>
        <div class="space-y-4 text-base leading-7 text-base-content/75">
            <p>@Localizer["NotebookText1"]</p>
            <p>@Localizer["NotebookText2"]</p>
        </div>
    </section>

    <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-3">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">@Localizer["OpenSourceEyebrow"]</p>
            <h2 class="text-3xl font-bold">@Localizer["OpenSourceTitle"]</h2>
            <p class="leading-7 text-base-content/70">@Localizer["OpenSourceText"]</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-lg border border-base-300 bg-base-100 p-5">
                <p class="text-sm font-semibold text-base-content/60">@Localizer["InstallCardLabel"]</p>
                <p class="mt-2 text-xl font-bold">@Localizer["InstallCardTitle"]</p>
                <p class="mt-2 text-sm leading-6 text-base-content/70">@Localizer["InstallCardText"]</p>
            </div>
            <div class="rounded-lg border border-base-300 bg-base-100 p-5">
                <p class="text-sm font-semibold text-base-content/60">@Localizer["LicenseCardLabel"]</p>
                <p class="mt-2 text-xl font-bold">@Localizer["LicenseCardTitle"]</p>
                <p class="mt-2 text-sm leading-6 text-base-content/70">@Localizer["LicenseCardText"]</p>
            </div>
        </div>
    </section>
</div>
