@* Modal dialog shown when the user tries to perform an LLM action without a configured provider.
   Include this partial on pages that trigger LLM calls.
   Open with: document.getElementById('llm-not-configured-modal').showModal() *@

<dialog id="llm-not-configured-modal" class="modal">
    <div class="modal-box">
        <h3 class="text-lg font-bold">@SharedLocalizer["LlmProviderNotConfiguredTitle"]</h3>
        <p class="py-4">
            @SharedLocalizer["LlmProviderNotConfiguredMessage"]
        </p>
        <div class="modal-action">
            <form method="dialog">
                <button class="btn btn-ghost">@SharedLocalizer["Close"]</button>
            </form>
            <a href="/Profile" class="btn btn-primary">
                <iconify-icon icon="mdi:account-cog"></iconify-icon>
                @SharedLocalizer["GoToProfile"]
            </a>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>@SharedLocalizer["CloseLowercase"]</button>
    </form>
</dialog>
