@page
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="space-y-6">
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h1 class="text-2xl font-semibold">@Localizer["HeroTitle"]</h1>
            <hr />
            <p class="text-sm text-base-content/70">
                @Localizer["HeroIntro"]
            </p>
            <p class="text-sm text-base-content/70">
                @Localizer["HeroTenantIsolation"]
            </p>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="card h-full bg-base-100 shadow">
            <div class="card-body">
                <h2 class="card-title">@Localizer["OverviewTitle"]</h2>
                <p class="text-sm text-base-content/70">
                    @Localizer["OverviewDescription"]
                </p>
                <div class="card-actions justify-end">
                    <a asp-page="/Help/Overview" class="btn btn-primary btn-sm">
                        <iconify-icon icon="mdi:map-outline"></iconify-icon>
                        @Localizer["OverviewButton"]
                    </a>
                </div>
            </div>
        </div>

        <div class="card h-full bg-base-100 shadow">
            <div class="card-body">
                <h2 class="card-title">@Localizer["AccessTitle"]</h2>
                <p class="text-sm text-base-content/70">
                    @Localizer["AccessDescription"]
                </p>
                <div class="card-actions justify-end">
                    <a asp-page="/Help/Access" class="btn btn-primary btn-sm">
                        <iconify-icon icon="mdi:shield-account-outline"></iconify-icon>
                        @Localizer["AccessButton"]
                    </a>
                </div>
            </div>
        </div>

        <div class="card h-full bg-base-100 shadow">
            <div class="card-body">
                <h2 class="card-title">@Localizer["ApiTitle"]</h2>
                <p class="text-sm text-base-content/70">
                    @Localizer["ApiDescription"]
                </p>
                <div class="card-actions justify-end">
                    <a asp-page="/Help/Api" class="btn btn-primary btn-sm">
                        <iconify-icon icon="mdi:api"></iconify-icon>
                        @Localizer["ApiButton"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
