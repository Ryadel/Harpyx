@page
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
    // Check if the user is authenticated
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
}

<div class="flex items-center justify-center min-h-[50vh]">
    <div class="card bg-base-100 shadow-lg w-full max-w-md">
        <div class="card-body items-center text-center space-y-4">
            <iconify-icon icon="mdi:lock-alert" class="text-5xl text-error"></iconify-icon>
            <h1 class="card-title text-2xl font-semibold text-error">@Localizer["PageHeading"]</h1>
            @if (isAuthenticated)
            {
                <p class="text-base-content/70">
                    @Localizer["AuthenticatedMessageLine1"]<br />
                    @Localizer["AuthenticatedMessageLine2"]
                </p>
            }
            else
            {
                <p class="text-base-content/70">
                    @Localizer["AnonymousMessageLine1"]<br />
                    @Localizer["AnonymousMessageLine2"]
                </p>
            }
            <a asp-page="/Index" class="btn btn-primary mt-2">
                <iconify-icon icon="mdi:arrow-left"></iconify-icon>
                @Localizer["BackToHome"]
            </a>
        </div>
    </div>
</div>
