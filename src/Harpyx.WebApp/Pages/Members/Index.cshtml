@page
@using Harpyx.Domain.Enums
@model Harpyx.WebApp.Pages.Members.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h1 class="text-2xl font-semibold">@Localizer["PageHeading"]</h1>
            <hr />
            <p class="text-sm text-base-content/70">
                @Localizer["CurrentTenantLabel"] <strong>@Model.CurrentTenantLabel</strong>
            </p>
            <p class="text-xs text-base-content/70">
                @Localizer["TenantScopedPermissions"]
            </p>
        </div>
    </div>

    <div class="card bg-base-100 shadow">
        <div class="card-body">
            @if (Model.Members.Count == 0)
            {
                @if (Model.CanManage)
                {
                    <partial name="_EmptyState" model="@(new EmptyStateViewModel(
                        Message: Localizer["NoMembers"].Value,
                        Action: new PageActionViewModel(
                            Label: Localizer["ManageUsersButton"].Value,
                            Page: "/Users/Index",
                            Icon: "mdi:account-plus")))" />
                }
                else
                {
                    <partial name="_EmptyState" model="@(new EmptyStateViewModel(
                        Message: Localizer["NoMembers"].Value))" />
                }
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>@Localizer["UserHeader"]</th>
                                <th>@Localizer["RoleHeader"]</th>
                                <th>@Localizer["CanGrantHeader"]</th>
                                <th>@Localizer["GrantedByHeader"]</th>
                                <th>@Localizer["GrantedAtHeader"]</th>
                                <th class="text-right">@Localizer["ActionsHeader"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var member in Model.Members)
                        {
                            var isSelfPersonalOwner =
                                Model.IsCurrentTenantPersonalOwnedByCurrentUser &&
                                Model.CurrentUserId == member.UserId;
                            <tr>
                                <td class="font-medium">@member.Email</td>
                                <td>
                                    @if (Model.CanManage && !isSelfPersonalOwner)
                                    {
                                        <form method="post" asp-page-handler="Update" class="inline-flex items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@member.UserId" />
                                            <select name="tenantRole" class="select select-bordered select-sm">
                                                @foreach (var role in Enum.GetValues<TenantRole>())
                                                {
                                                    if (role == member.TenantRole)
                                                    {
                                                        <option value="@role" selected="selected">@role</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@role">@role</option>
                                                    }
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-ghost btn-sm" title="@Localizer["SaveButton"]" aria-label="@Localizer["SaveButton"]">
                                                <iconify-icon icon="mdi:content-save"></iconify-icon>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge badge-ghost">@member.TenantRole</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(member.CanGrant ? "badge-info" : "badge-ghost")">
                                        @(member.CanGrant ? Localizer["Yes"] : Localizer["No"])
                                    </span>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(member.GrantedByEmail) ? "-" : member.GrantedByEmail)</td>
                                <td>@(member.GrantedAt?.ToString("g") ?? "-")</td>
                                <td class="text-right">
                                    @if (Model.CanManage)
                                    {
                                        if (!isSelfPersonalOwner)
                                        {
                                            <form method="post" asp-page-handler="Remove" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@member.UserId" />
                                                <button type="submit" class="btn btn-ghost btn-sm text-error"
                                                        onclick="return confirm('@Localizer["RemoveConfirmation"]');"
                                                        title="@Localizer["RemoveButton"]" aria-label="@Localizer["RemoveButton"]">
                                                    <iconify-icon icon="mdi:account-remove"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
