# Harpyx host-local overrides (.env.local)
#
# Copy this file to `.env.local` when running Harpyx.WebApp or Harpyx.Worker
# from the IDE / dotnet run while using Docker Compose only for dependencies.
# Docker Compose does not read this file.

# --- Database (SQL Server) ---
Database__Host=localhost
Database__Port=14330

# --- MinIO (S3-compatible storage) ---
Minio__Endpoint=localhost:9000

# --- RabbitMQ ---
RabbitMQ__HostName=localhost

# --- Redis ---
Redis__ConnectionString=localhost:6379

# --- Malware scanning (ClamAV) ---
MalwareScan__Host=localhost

# --- OpenSearch ---
OpenSearch__Endpoint=https://localhost:9200
